# Twin Pizza Voice Receptionist - Environment Configuration

# Server Port
PORT=5000

# Supabase Credentials (Required)
# VITE_SUPABASE_URL from root .env
SUPABASE_URL=https://hsylnrzxeyqxczdalurj.supabase.co
# Use service_role key to bypass Row-Level Security (RLS) for server writes
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI Credentials (Required if using WebSocket streaming mode)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Twilio Credentials (Required for phone calls and TwiML redirect)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Human Backup Transfer Number
TRANSFER_PHONE=0232112613
