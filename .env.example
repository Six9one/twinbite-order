# ══════════════════════════════════════════════════════════════════
#  TwinPizza Hub — Configuration
#  Copiez ce fichier en ".env" et remplissez les valeurs
# ══════════════════════════════════════════════════════════════════

# Supabase (base de données)
VITE_SUPABASE_PROJECT_ID="votre-project-id"
VITE_SUPABASE_URL="https://votre-project.supabase.co"
VITE_SUPABASE_ANON_KEY="votre-anon-key"
VITE_SUPABASE_PUBLISHABLE_KEY="votre-anon-key"

# Mapbox (optionnel — carte pour livraisons)
VITE_MAPBOX_PUBLIC_TOKEN="votre-token-mapbox"

# Imprimante thermique — IP de l'imprimante sur votre réseau local
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
